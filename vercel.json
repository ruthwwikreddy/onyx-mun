{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/embed/promo",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://onyxmunhyd.in https://www.onyxmunhyd.in https://www.gathrly.in https://gathrly.in http://localhost:* https://localhost:* http://127.0.0.1:* https://127.0.0.1:*;"
        }
      ]
    },
    {
      "source": "/embed/promo.html",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://onyxmunhyd.in https://www.onyxmunhyd.in https://www.gathrly.in https://gathrly.in http://localhost:* https://localhost:* http://127.0.0.1:* https://127.0.0.1:*;"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/best-mun",
      "destination": "/best-mun-hyderabad",
      "permanent": true
    },
    {
      "source": "/mun-hyderabad",
      "destination": "/best-mun-hyderabad",
      "permanent": true
    },
    {
      "source": "/hyderabad-mun",
      "destination": "/best-mun-hyderabad",
      "permanent": true
    },
    {
      "source": "/delegate-application",
      "destination": "/round-1",
      "permanent": true
    },
    {
      "source": "/delegate-application.html",
      "destination": "/round-1",
      "permanent": true
    }
  ]
}
